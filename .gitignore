.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# 타입 체크 / 린트 캐시
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/

# Jupyter
.ipynb_checkpoints/

# ===== IDE / 에디터 =====
.vscode/
.idea/
*.swp
*.swo
*~
